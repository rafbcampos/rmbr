{
  "$schema": "https://raw.githubusercontent.com/nicknisi/oxlint-config/refs/heads/main/schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error"
  },
  "ignorePatterns": ["node_modules", "dist", "coverage"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
